# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=

# Backend
BIND_ADDR=0.0.0.0:8080
DATABASE_URL=postgres://floorplan:floorplan@localhost:5432/floorplan
ARTIFACT_DIR=./data/artifacts
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:5173
AUTH_ALLOWED_ORIGINS=http://localhost:5173

# OpenPT-compatible auth env names found on 192.168.1.174:
AUTH_SECRET=change-me-in-production
AUTH_COOKIE_NAME=glb_floorplan_session
AUTH_SESSION_DAYS=30

# Google sign-in. In local dev, leaving GOOGLE_CLIENT_ID empty enables dev:email tokens.
GOOGLE_CLIENT_ID=

# Optional Gmail API settings for account/notification email reuse.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SEND_FROM=

MAX_UPLOAD_MB=250
MONTHLY_FREE_SAVES=5
